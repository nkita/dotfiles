{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#c8d3f5",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "▌ ",
    "color": "#636da6",
    "italic": true
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "bold": true
  },
  "h1": {
    "prefix": "  ",
    "suffix": "  ",
    "color": "#222436",
    "background_color": "#82aaff",
    "bold": true,
    "block_suffix": "\n"
  },
  "h2": {
    "color": "#82aaff",
    "bold": true
  },
  "h3": {
    "color": "#86e1fc"
  },
  "h4": {
    "color": "#b4f9f8"
  },
  "h5": {
    "color": "#828bb8"
  },
  "h6": {
    "color": "#636da6"
  },
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true,
    "color": "#fca7ea"
  },
  "strong": {
    "bold": true,
    "color": "#ff966c"
  },
  "hr": {
    "color": "#2f334d",
    "format": "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
  },
  "item": {},
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "unticked_prefix": "  ○ ",
    "ticked_prefix": "  ● ",
    "ticked_color": "#c3e88d",
    "unticked_color": "#636da6"
  },
  "link": {
    "color": "#82aaff",
    "underline": true
  },
  "link_text": {
    "color": "#82aaff",
    "bold": true
  },
  "image": {
    "color": "#c3e88d"
  },
  "image_text": {
    "color": "#c3e88d"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#c3e88d",
    "background_color": "#323232"
  },
  "code_block": {
    "color": "#c8d3f5",
    "background_color": "#323232",
    "margin": 2,
    "chroma_style": "tokyonight-moon"
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "html_block": {},
  "html_span": {}
}
